{
    "name": "image-filter",
    "version": "0.0.1",
    "description": "solid js libraries",
    "main": "lib/index.js",
    "scripts": {
        "start": "mo start library solid",
        "build": "mo build library solid",
        "stylelint": "mo stylelint [site] --fix",
        "eslint": "mo eslint [site] --fix",
        "changelog": "mo changelog CHANGELOG.md && git add CHANGELOG.md",
        "prepare": "mo githooks pre-commit=\"npm run precommit\" commit-msg=\"npx --no -- commitlint --edit ${1}\"",
        "precommit": "npm run stylelint && npm run eslint && npm run changelog"
    },
    "license": "MIT",
    "keywords": [
        "image-filter",
        "ui libraries"
    ],
    "devDependencies": {
        "@commitlint/cli": "19.8.0",
        "@commitlint/config-conventional": "19.8.0",
        "@moneko/core": "3.43.3",
        "@moneko/css": "1.2.0",
        "@moneko/request": "1.5.4",
        "@types/crypto-js": "^4.2.2",
        "crypto-js": "^4.2.0",
        "n-code-live": "2.1.0",
        "neko-ui": "^2.11.0",
        "solid-element": "1.8.1"
    },
    "dependencies": {
        "@moneko/solid": "1.11.1",
        "context-filter-polyfill": "^0.3.22",
        "solid-js": "1.8.23"
    },
    "repository": "https://github.com/monako97/image-filter",
    "author": "moneko",
    "files": [
        "LICENSE",
        "README.md",
        "es",
        "lib",
        "types"
    ],
    "module": "es/index.js",
    "types": "types/index.d.ts",
    "exports": {
        ".": {
            "require": "./lib/index.js",
            "import": "./es/index.js"
        },
        "./*": [
            "./*"
        ]
    }
}